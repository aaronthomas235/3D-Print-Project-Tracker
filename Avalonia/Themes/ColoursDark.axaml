<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<SolidColorBrush x:Key="MainBackgroundBrush" Color="#1C1C1E" />                 <!-- Near-black neutral: softer than pure charcoal, modern low-fatigue base -->
	<SolidColorBrush x:Key="NavigationBarBackgroundBrush" Color="#18181A" />        <!-- Slightly darker than main surface for subtle top-level separation -->
	<SolidColorBrush x:Key="PanelBackgroundBrush" Color="#232326" />                <!-- Soft elevated surface tone: improves panel distinction without heavy contrast -->
	<SolidColorBrush x:Key="BorderBrush" Color="#3A3A3D" />                         <!-- Balanced graphite border: visible but not visually sharp -->
	<SolidColorBrush x:Key="TextBrush" Color="#D4D4D4" />                           <!-- Soft light grey: readable without harsh white glare -->
	<SolidColorBrush x:Key="PointerOverBrush" Color="#2C2C30" />                    <!-- Gentle hover surface for interactive feedback -->
	<SolidColorBrush x:Key="PointerPressedBrush" Color="#3B82F6" />                 <!-- Controlled blue accent: modern active interaction color -->
	<SolidColorBrush x:Key="CheckBoxBorderBrush" Color="#D4D4D4" />                 <!-- Matches text tone for consistent control visibility -->
	<SolidColorBrush x:Key="TreeChevronBrush" Color="#D4D4D4" />                    <!-- Same text-linked tone for hierarchy consistency -->
	<SolidColorBrush x:Key="PanelBorderBrush" Color="#2F2F33" />                    <!-- Slightly deeper panel edge to define surfaces cleanly -->
	<SolidColorBrush x:Key="DividerBrush" Color="#5A5A5F" />                        <!-- Soft divider grey: separates sections without visual harshness -->
	<SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#5B6B7C" />        <!-- Muted steel blue-grey: calmer action emphasis, matches refined light theme -->
	<SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF" />        <!-- White text ensures strong readability on darker button surface -->
	<SolidColorBrush x:Key="PrimaryButtonFileHoverBrush" Color="#506070" />         <!-- Slightly darker hover state for subtle interaction depth -->
	<SolidColorBrush x:Key="PrimaryButtonFilePressedBrush" Color="#445261" />       <!-- Deeper pressed state to reinforce click feedback -->
	<SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground" Color="#D4D4D4" />     <!-- Matches text tone so dropdown glyph feels integrated with control typography -->
</ResourceDictionary>
