<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Panel Container -->
    <Style Selector="Grid.PanelContainer">
		<Setter Property="Margin" Value="{DynamicResource Margin.2}"/>
    </Style>

    <Style Selector="Border.PanelContainer">
		<Setter Property="Margin" Value="{DynamicResource Margin.1}"/>
    </Style>

    <!-- Common Panel -->
    <Style Selector="Border.PanelCommon">
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.2}"/>
        <Setter Property="Padding" Value="{DynamicResource Padding.3}"/>
        <Setter Property="Margin" Value="{DynamicResource Margin.2}"/>
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource Border.Thin}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
    </Style>

    <!-- Navigation Panel -->
    <Style Selector="Border.PanelNavigation">
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.2}"/>
        <Setter Property="Padding" Value="{DynamicResource Padding.2}"/>
        <Setter Property="Margin" Value="{DynamicResource Margin.2}"/>
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource Border.Thin}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
    </Style>

    <Style Selector="StackPanel.ThemePanel">
        <Setter Property="Spacing" Value="{DynamicResource Space.2}"/>
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Divider -->
    <Style Selector="Border.Divider">
        <Setter Property="Height" Value="{DynamicResource Space.1}"/>
        <Setter Property="Background" Value="{DynamicResource DividerBrush}"/>
        <Setter Property="Margin" Value="{DynamicResource Margin.3}"/>
    </Style>

    <!-- Profile List Item -->
    <Style Selector="Border.ProfileListItem">
        <Setter Property="Padding" Value="{DynamicResource Padding.2}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.1}"/>
    </Style>

</Styles>
