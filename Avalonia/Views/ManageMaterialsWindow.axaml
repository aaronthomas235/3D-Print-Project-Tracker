<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ThreeDPrintProjectTracker.Avalonia.ManageMaterialsWindow"
        Background="{DynamicResource MainBackgroundBrush}"
		Icon="/Assets/3D_Print_Project_Tracker.ico"
        Title="ManageMaterialsWindow"
        WindowStartupLocation="CenterOwner"
		Width="{DynamicResource Window.Editor.Width}"
		Height="{DynamicResource Window.Editor.Height}"
		MinWidth="{DynamicResource Window.Editor.MinWidth}"
		MinHeight="{DynamicResource Window.Editor.MinHeight}">

    <TextBox Text="Hello There" />

</Window>
