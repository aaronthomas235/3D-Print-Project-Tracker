<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ThreeDPrintProjectTracker.Avalonia.App"
             xmlns:local="using:ThreeDPrintProjectTracker.Avalonia"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />

        <StyleInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Styles/Navigation.axaml"/>
        <StyleInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Styles/Images.axaml"/>
		<StyleInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Styles/Treeview.axaml"/>
		<StyleInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Styles/Typography.axaml"/>
		<StyleInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Styles/Panels.axaml"/>
        <StyleInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Styles/Buttons.axaml"/>
        <StyleInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Styles/Inputs.axaml"/>

    </Application.Styles>

    <Application.Resources>
		<ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <ResourceInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Styles/DesignTokens.axaml" />

                <ResourceInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Themes/ColoursLight.axaml" />
                <ResourceInclude Source="avares://ThreeDPrintProjectTracker.Avalonia/Themes/ColoursDark.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>