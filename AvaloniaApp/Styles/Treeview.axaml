<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TreeView Chevron -->
    <Style Selector="TreeView.ProjectTree TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron Path">
        <Setter Property="Fill" Value="{DynamicResource TreeChevronBrush}" />
    </Style>

    <Style Selector="TreeView.ProjectTree TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TreeChevronBrush}" />
    </Style>

    <!-- TreeView CheckBox -->
    <Style Selector="TreeView.ProjectTree CheckBox:unchecked /template/ Border#NormalRectangle">
        <Setter Property="Margin" Value="{DynamicResource Margin.Control}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CheckBoxBorderBrush}" />
    </Style>

    <Style Selector="StackPanel.TreeViewItemRow">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Spacing" Value="{DynamicResource Gap.TreeViewItemRow}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
</Style>
</Styles>
