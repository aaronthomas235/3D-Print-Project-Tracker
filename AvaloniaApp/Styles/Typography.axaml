<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Text Style -->
    <Style Selector="TextBlock.BaseText">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <!-- Numeric Text -->
    <Style Selector="TextBlock.NumericText">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <Style Selector="TextBlock.SecondaryStatusText">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="{DynamicResource Opacity.Secondary}" />
    </Style>

    <!-- Editor Labels -->
    <Style Selector="TextBlock.EditorLabel">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Label}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Section Headers -->
    <Style Selector="TextBlock.SectionHeader">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Section}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Margin" Value="{DynamicResource Margin.Control}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.PanelHeader">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Section}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Detail Labels -->
    <Style Selector="TextBlock.DetailLabel">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Label}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</Styles>
