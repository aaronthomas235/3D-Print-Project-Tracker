<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Button -->
    <Style Selector="Button.PrimaryButton">
        <Setter Property="MinWidth" Value="{DynamicResource Width.Button.Primary}" />
        <Setter Property="MinHeight" Value="{DynamicResource Height.Button.Primary}" />
        <Setter Property="Padding" Value="{DynamicResource Padding.Control}" />
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Border.Thin}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
        <Setter Property="Opacity" Value="{DynamicResource Opacity.Strong}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Hover -->
    <Style Selector="Button.PrimaryButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonFileHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- Pressed -->
    <Style Selector="Button.PrimaryButton:pressed">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonFilePressedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style Selector="Button.ToolbarButton">
		<Setter Property="Width" Value="{DynamicResource Width.Button.Toolbar}" />
        <Setter Property="Height" Value="{DynamicResource Height.Button.Toolbar}" />
        <Setter Property="Padding" Value="{DynamicResource Padding.None}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{DynamicResource Border.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Small}" />
        <Setter Property="Opacity" Value="{DynamicResource Opacity.Secondary}" />
    </Style>

    <Style Selector="Button.ToolbarButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="Opacity" Value="{DynamicResource Opacity.Full}" />
    </Style>

    <Style Selector="Button.ToolbarButton:pressed">
        <Setter Property="Opacity" Value="{DynamicResource Opacity.Full}" />
    </Style>

    <Style Selector="StackPanel.ButtonContentRow">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="{DynamicResource Gap.ButtonContentRow}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

</Styles>
