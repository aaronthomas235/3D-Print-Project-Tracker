<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Add Styles Here -->
  <Style Selector="Image.MenuIcon">
      <Setter Property="Width" Value="{DynamicResource Size.Icon.S}"/>
      <Setter Property="Height" Value="{DynamicResource Size.Icon.S}"/>
  </Style>

  <Style Selector="Image.PrimaryButtonIcon">
      <Setter Property="Width" Value="{DynamicResource Size.Icon.L}"/>
      <Setter Property="Height" Value="{DynamicResource Size.Icon.L}"/>	  
  </Style>

  <Style Selector="Image.ToolbarButtonIcon">
      <Setter Property="Width" Value="{DynamicResource Size.Icon.S}"/>
      <Setter Property="Height" Value="{DynamicResource Size.Icon.S}"/>	  
  </Style>

</Styles>
