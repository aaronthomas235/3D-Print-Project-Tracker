<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Text Style -->
    <Style Selector="TextBlock.BaseText">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.3}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <!-- Numeric Text -->
    <Style Selector="TextBlock.NumericText">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <!-- Editor Labels -->
    <Style Selector="TextBlock.EditorLabel">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.4}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Section Headers -->
    <Style Selector="Label.SectionHeader">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize.5}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Margin" Value="{DynamicResource Margin.2}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Detail Labels -->
    <Style Selector="Label.DetailLabel">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.3}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</Styles>
